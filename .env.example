# ---------- Database ----------
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# ---------- App ----------
APP_URL="https://your-app.vercel.app"     # public URL of this deployment (no trailing slash)
AUTH_SECRET="generate-a-long-random-string"

# ---------- Shopify App (Partner Dashboard -> your app) ----------
SHOPIFY_API_KEY="from-partner-dashboard"
SHOPIFY_API_SECRET="from-partner-dashboard"
SHOPIFY_API_VERSION="2025-01"
SHOPIFY_BILLING_TEST="1"                  # 1 = test charges while developing; remove for production

# ---------- AI features ----------
ANTHROPIC_API_KEY="sk-ant-..."

# ---------- Optional: Google Calendar sync ----------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------- Optional: Stripe payment links ----------
STRIPE_SECRET_KEY=""
